generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id          String   @id @default(uuid())
  title       String
  description String?
  servings    Int?
  prepTime    Int?
  cookTime    Int?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Folder {
  id        String   @id @default(uuid())
  name      String

  createdAt DateTime @default(now())
}

model Reminder {
  id        String   @id @default(uuid())
  title     String
  detail    String?
  complete  Boolean  @default(false)

  createdAt DateTime @default(now())
}